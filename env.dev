# 开发环境配置
ENVIRONMENT=development

# Django app related
DJANGO_SETTINGS_MODULE=TeleAgent.settings
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=DEBUG

# Gunicorn related
GUNICORN_WORKERS=2
GUNICORN_WORKER_CLASS=sync
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_TIMEOUT=30
GUNICORN_KEEP_ALIVE=2
GUNICORN_LOG_LEVEL=debug

# HTTPS（无域名时用自签名证书，启动脚本会自动生成）
USE_HTTPS=True
CSRF_TRUSTED_ORIGINS=https://localhost:9443,http://localhost:9020

# Web auth cookies (Next.js Web)
WEB_JWT_ACCESS_COOKIE=sd_access
WEB_JWT_REFRESH_COOKIE=sd_refresh
WEB_CSRF_COOKIE_NAME=sd_csrf
WEB_CSRF_HEADER_NAME=X-SD-CSRF
WEB_COOKIE_SAMESITE=Lax

# 域名配置
APP_DOMAIN=localhost

# Database related (Docker: POSTGRES_HOST 由 docker-compose 设为 DbTeleAgent)
DATABASE_URL=postgres://dap_db_user:dap_db_password@DbTeleAgent:5432/dap_db
POSTGRES_USER=dap_db_user
POSTGRES_PASSWORD=dap_db_password
POSTGRES_DB=dap_db
POSTGRES_HOST=DbTeleAgent
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C

LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=100
LOG_FORMAT=verbose

# Nginx related
NGINX_HTTP_PORT=9020
NGINX_HTTPS_PORT=9443

DATA_PREFIX=~/Documents/TeleAgent