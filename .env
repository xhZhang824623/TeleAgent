# 生产/云端环境配置（部署前请按实际环境修改）
ENVIRONMENT=production

# Django
DJANGO_SETTINGS_MODULE=TeleAgent.settings
DEBUG=False
# 必改：用 `python -c "import secrets;print(secrets.token_urlsafe(50))"` 生成填入（DEBUG=False 启动会强制校验）
SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret_key
# 云端部署：改为你的公网 IP 或域名，多个用逗号分隔（仅 IP 时填如 1.2.3.4）
ALLOWED_HOSTS=localhost,127.0.0.1,111.229.198.55
LOG_LEVEL=INFO

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=sync
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_TIMEOUT=30
GUNICORN_KEEP_ALIVE=2
GUNICORN_LOG_LEVEL=info

# HTTPS / CSRF（用 IP 访问时改为 http://你的IP:9020,https://你的IP:9443）
USE_HTTPS=True
CSRF_TRUSTED_ORIGINS=https://111.229.198.55:9443,http://111.229.198.55:9020

# Web cookies（Broker 前端用）
WEB_JWT_ACCESS_COOKIE=sd_access
WEB_JWT_REFRESH_COOKIE=sd_refresh
WEB_CSRF_COOKIE_NAME=sd_csrf
WEB_CSRF_HEADER_NAME=X-SD-CSRF
WEB_COOKIE_SAMESITE=Lax

# 应用域名（云端部署时改为你的域名或 IP）
APP_DOMAIN=111.229.198.55

# 数据库（容器内服务名为 DbTeleAgent，勿改）
POSTGRES_HOST=DbTeleAgent
POSTGRES_USER=dap_db_user
# 必改：首次部署前设一个强密码（与 DATABASE_URL 保持一致；DB 已初始化后再改需同步重置数据库）
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=dap_db
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C
DATABASE_URL=postgres://dap_db_user:CHANGE_ME_strong_db_password@DbTeleAgent:5432/dap_db

LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=100
LOG_FORMAT=verbose

# Nginx 端口（宿主机映射）
NGINX_HTTP_PORT=9020
NGINX_HTTPS_PORT=9443

# 数据目录（云端建议改为持久化盘，如 /data/teleagent）
DATA_PREFIX=/data/teleagent